# Sanity CMS Configuration
# Get these from https://manage.sanity.io/

# Public environment variables (safe to commit)
NEXT_PUBLIC_SANITY_PROJECT_ID=wj6g4kk6
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_STUDIO_PATH=/studio

# Private environment variables (DO NOT commit)
# Read token for fetching published content
SANITY_API_READ_TOKEN=your_read_token_here

# Write token for publishing and updating content
# Required for admin operations (publishing, creating, updating documents)
SANITY_API_WRITE_TOKEN=your_write_token_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://www.seomothra.com

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: External integrations
# WEBHOOK_URL=your_webhook_url
# ANALYTICS_ID=your_analytics_id
